#!/usr/bin/env bash
#
# devcontainer-init — copy one of this dotfiles repo's example dev container
# templates (see devcontainer-templates/) into another repo you're working on.
#
# Usage:
#   devcontainer-init <template-name> [target-dir]   # target-dir defaults to .
#   devcontainer-init                                 # list available templates
#
# Host-only: this script isn't installed inside dev containers themselves
# (see .chezmoiignore.tmpl, gated on devcontainer_enabled) — there's nothing
# to deploy templates *to* from inside a container.

set -euo pipefail

TEMPLATES_DIR="$(chezmoi source-path)/devcontainer-templates"

_list_templates() {
  echo "Available templates:"
  for dir in "$TEMPLATES_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    echo "  - $(basename "$dir")"
  done
}

FORCE=false
ARGS=()
for arg in "$@"; do
  case "$arg" in
  --force) FORCE=true ;;
  *) ARGS+=("$arg") ;;
  esac
done

if [[ "${#ARGS[@]}" -lt 1 ]]; then
  _list_templates
  exit 0
fi

TEMPLATE_NAME="${ARGS[0]}"
TARGET_DIR="${ARGS[1]:-.}"
TEMPLATE_SRC="$TEMPLATES_DIR/$TEMPLATE_NAME"

if [[ ! -d "$TEMPLATE_SRC" ]]; then
  echo "ERROR: Unknown template '$TEMPLATE_NAME'." >&2
  _list_templates >&2
  exit 1
fi

if [[ -e "$TARGET_DIR/.devcontainer" && "$FORCE" != true ]]; then
  echo "ERROR: $TARGET_DIR/.devcontainer already exists. Pass --force to overwrite." >&2
  exit 1
fi

mkdir -p "$TARGET_DIR"
cp -r "$TEMPLATE_SRC/." "$TARGET_DIR/"

echo "Copied '$TEMPLATE_NAME' into $TARGET_DIR/.devcontainer"
echo ""
echo "Next steps:"
echo "  - Review $TARGET_DIR/.devcontainer/devcontainer.json for any // TODO comments"
echo "  - Open in VS Code / run 'devcontainer up --workspace-folder $TARGET_DIR'"
