# Extra CLI tooling for a WSL dev host that drives dev containers — installed by
# bootstrap-cli.sh --wsl on top of base.Brewfile. No language toolchains (those
# live inside the containers) and no GUI apps (terminal/editor GUI is on Windows).
# Reference implementation for the Development Containers specification
brew "devcontainer"
# Terminal-based AI coding assistant
cask "claude-code"
# Like neofetch, but much faster because written mostly in C
brew "fastfetch"
# Centralized update utility
brew "topgrade"
