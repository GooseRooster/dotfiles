tap "tinted-theming/tinted", trusted: true
tap "gooserooster/gnomad", "https://github.com/GooseRooster/homebrew-gnomad", trusted: true

# Change the theme of your terminal, text editor and anything else with one command.
brew "tinted-theming/tinted/tinty", trusted: true

# Tool to convert a Wallpaper's color scheme / palette
brew "gowall"

# A lightweight TUI for managing tinted color schemes in the GNOME shell
brew "gooserooster/gnomad/gnomad"


