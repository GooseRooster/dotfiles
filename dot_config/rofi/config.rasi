configuration {
  modes: [ combi ];
  combi-modes: [ window, drun ];
}
/* Dark theme. */
@import "~/.cache/wal/colors-rofi-dark"

window {
  border-radius: 12px;
}

element-icon {
  background-color: @background;
  border-radius: 4px;
  padding: 3px;
}

element-text.selected {
  text-color: @background;
}


