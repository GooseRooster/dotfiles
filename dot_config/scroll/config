# ~/.config/scroll/config
# Ported from Hyprland Lua config. Read `man 5 scroll` for full reference.

### Variables
set $mod Mod4
set $left Left
set $right Right
set $up Up
set $down Down

set $term kitty
set $filemanager kitty -e yazi
set $menu fuzzel
set $browser zen-browser
set $steam steam
set $music flatpak run io.github.lullabyX.sone
set $ipc noctalia msg

### Output configuration
#
# Catch-all: enables HDR and VRR on whatever monitor is connected.
# Run `scrollmsg -t get_outputs` to find your connector name (e.g. DP-1),
# then replace * with that name and uncomment position if needed.
#
output * {
    resolution 3440x1440@165Hz
    hdr on
    adaptive_sync on
}
# output DP-1 {
#     resolution 3440x1440@165
#     position 0,0
#     hdr on
#     adaptive_sync on
# }

### Appearance
default_border pixel 2
default_decoration border_radius 10 shadow true shadow_dynamic true shadow_size 40 shadow_blur 20 shadow_offset 10 10 shadow_color #1a1a1aee dim false dim_color #00000040

gaps inner 5
gaps outer 20

# Noctalia / Catppuccin Mocha color scheme
# client.focused        <border>  <bg>      <text>    <indicator> <child_border>
client.focused          #94e2d5   #1e1e2e   #cdd6f4   #94e2d5     #94e2d5
client.focused_inactive #1e1e2e   #1e1e2e   #585b70   #1e1e2e     #1e1e2e
client.unfocused        #1e1e2e   #1e1e2e   #585b70   #1e1e2e     #1e1e2e

### Scroll layout
layout_default_width 0.5
layout_default_height 1.0
layout_widths [0.33333333 0.5 0.666666667 1.0]
layout_heights [0.33333333 0.5 0.666666667 1.0]
focus_wrapping no
maximize_if_single false

### Animations
animations {
    enabled yes
    default yes 300 var 3 [ 0.215 0.61 0.355 1 ]
    window_open yes 300 var 3 [ 0 0 1 1 ]
    window_move yes 300 var 3 [ 0.215 0.61 0.355 1 ] off 0.05 6 [0 0.6 0.4 0 1 0 0.4 -0.6 1 -0.6]
    window_size yes 300 var 3 [ -0.35 0 0 0.5 ]
    workspace_switch yes 400 var 3 [ 0.215 0.61 0.355 1 ]
    window_fullscreen yes 500 var 3 [ 0.3 0.5 0.4 1 ]
}

### Input
input type:keyboard {
    xkb_layout "us"
}

input type:pointer {
    accel_profile flat
    pointer_accel 0
}

input type:touchpad {
    natural_scroll disabled
    tap enabled
    dwt enabled
}

### Autostart
exec uwsm finalize SWAYSOCK I3SOCK
exec uwsm app -- noctalia
exec uwsm app -- udiskie

### Gestures (3-finger swipe = workspace, 4-finger up = overview)
bindgesture swipe:3:right workspace next
bindgesture swipe:3:left workspace prev
bindgesture swipe:4:up scale_workspace overview

### Drag/resize floating windows with mod + mouse
floating_modifier $mod normal

### Window rules
for_window [all] inhibit_idle fullscreen
for_window [app_id="filechooser"] floating enable, resize set 1000 650, move position center

### Key bindings

## App launchers
bindsym $mod+Home exec $term
bindsym $mod+e exec $filemanager
bindsym $mod+b exec $browser
bindsym $mod+i exec kitty -e yazi ~/.config
bindsym $mod+space exec $menu
bindsym $mod+g exec $steam
bindsym $mod+m exec $music

## Window management
bindsym $mod+q kill
bindsym $mod+f fullscreen
bindsym $mod+Shift+f floating toggle
bindsym $mod+j layout_transpose

## Focus (arrow keys)
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

## Move windows (Alt + arrows)
bindsym $mod+Alt+Left move left
bindsym $mod+Alt+Right move right
bindsym $mod+Alt+Up move up
bindsym $mod+Alt+Down move down

## Resize windows (Shift + arrows — mirrors Hyprland behaviour)
bindsym $mod+Shift+Right resize grow width 20px
bindsym $mod+Shift+Left resize shrink width 20px
bindsym $mod+Shift+Down resize grow height 20px
bindsym $mod+Shift+Up resize shrink height 20px

## Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

## Scroll workspaces
bindsym $mod+Ctrl+Right workspace next
bindsym $mod+Ctrl+Left workspace prev
bindsym --whole-window $mod+button5 workspace next
bindsym --whole-window $mod+button4 workspace prev

## Scratchpad (replaces Hyprland's special:magic workspace)
bindsym $mod+s scratchpad show
bindsym $mod+Shift+s move scratchpad

## Scroll-specific: column/row size cycling
bindsym $mod+minus cycle_size h prev
bindsym $mod+equal cycle_size h next
bindsym $mod+Shift+minus cycle_size v prev
bindsym $mod+Shift+equal cycle_size v next

## Scroll-specific: overview
bindsym --no-repeat $mod+Tab scale_workspace overview
bindsym --no-repeat $mod+Shift+Tab scale_workspaces toggle

## Reload config
bindsym $mod+Shift+c reload

## Screenshots (grim + slurp + swappy)
# swappy handles save location, annotation, and clipboard copy.
# Configure save dir in ~/.config/swappy/config (save_dir=~/Pictures/Screenshots)
set $satty swappy -f -
bindsym Print exec grim -g "$(slurp -d)" - | $satty
bindsym $mod+Print exec grim -o "$(scrollmsg -t get_outputs | jq -r '.[] | select(.focused) | .name')" - | $satty
bindsym $mod+Shift+Print exec scrollmsg -t get_tree | jq -r '.. | select(.focused?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | grim -g - - | $satty

## Screen recording (wl-screenrec, 10-bit HEVC for HDR)
bindsym $mod+F9 exec bash -c 'wl-screenrec --codec hevc --encode-pixfmt p010 --audio -f ~/Videos/Recordings/$(date +%Y%m%d_%H%M%S).mp4 &'
bindsym $mod+F10 exec pkill -INT wl-screenrec

## Noctalia IPC
bindsym $mod+comma exec $ipc panel-toggle control-center
bindsym $mod+Delete exec $ipc panel-toggle session
bindsym $mod+l exec $ipc screen-lock
bindsym $mod+Shift+l exec bash -c 'noctalia msg screen-lock && systemctl suspend'
bindsym $mod+F1 exec $ipc panel-toggle control-center calendar
bindsym $mod+End exec $ipc settings-toggle
bindsym $mod+F2 exec $ipc panel-toggle control-center system
bindsym $mod+v exec $ipc panel-toggle clipboard

## Media / volume keys (via Noctalia IPC, work on lock screen)
bindsym --locked XF86AudioRaiseVolume exec $ipc volume-up
bindsym --locked XF86AudioLowerVolume exec $ipc volume-down
bindsym --locked XF86AudioMute exec $ipc volume-mute
bindsym --locked XF86AudioMicMute exec $ipc mic-mute
bindsym --locked XF86MonBrightnessUp exec $ipc brightness-up
bindsym --locked XF86MonBrightnessDown exec $ipc brightness-down
bindsym --locked XF86AudioNext exec $ipc media next
bindsym --locked XF86AudioPlay exec $ipc media toggle
bindsym --locked XF86AudioPrev exec $ipc media previous
