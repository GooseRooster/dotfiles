# ── Homebrew bootstrap ────────────────────────────────────────────────────────
# Prefix resolved once at `chezmoi apply` (see .chezmoitemplates/brew-prefix):
# /var/home on immutable/ostree hosts, /home on WSL and traditional distros.
let brew_prefix = "{{ includeTemplate "brew-prefix" }}"

$env.HOMEBREW_PREFIX     = $brew_prefix
$env.HOMEBREW_CELLAR     = $"($brew_prefix)/Cellar"
$env.HOMEBREW_REPOSITORY = $brew_prefix
$env.PATH = ($env.PATH | prepend [
    $"($brew_prefix)/bin"
    $"($brew_prefix)/sbin"
])

#SSH
let existing_sock = ($env.SSH_AUTH_SOCK? | default "")
if ($existing_sock == "") or (not ($existing_sock | path exists)) {
    let uid = (id -u | str trim)
    $env.XDG_RUNTIME_DIR = ($env.XDG_RUNTIME_DIR? | default $"/run/user/($uid)")
    $env.SSH_AUTH_SOCK = $"($env.XDG_RUNTIME_DIR)/ssh-agent.socket"
}


# ── Toolchain env (depends on brew being on PATH above) ────────────────────────
# Add any environment variables here for dev tooling, if needed

# Runs `exec` only if `cmd` resolves on PATH — lets a leaner host (e.g. a
# devcontainer/WSL host that skips devtools.Brewfile) source this file
# without every tool being installed.
def try-cmd-init [cmd: string, exec: closure] {
    if (which $cmd | is-not-empty) {
        do $exec
    }
}

# `brew --prefix <formula>` exits non-zero for an uninstalled formula.
# Returning null instead of erroring keeps env.nu sourcing when the formula
# was skipped (e.g. dotnet/rustup on bootstrap-cli.sh hosts).
def brew-prefix-safe [formula: string] {
    let result = (do -i { ^brew --prefix $formula } | complete)
    if $result.exit_code == 0 { $result.stdout | str trim } else { null }
}

# dotnet - SSL dev cert location, dotnet root for tools.
# Roslyn LSP expects this populated, but brew doesn't do that for you.
# Candidates must actually contain OpenSSL subject-hash symlinks (<hash>.0) —
# on Fedora/Bluefin /etc/ssl/certs exists too, but only holds two bundle-file
# symlinks, not a real hash dir, so SSL_CERT_DIR would silently find nothing.
def get-system-cert-dir [] {
    let candidates = [
        "/etc/pki/tls/certs"    # Fedora/RHEL/Bluefin
        "/etc/ssl/certs"        # Debian/Ubuntu
    ]
    $candidates | where {|p|
        ($p | path exists) and ((ls $p | where name =~ '[0-9a-f]{8}\.[0-9]+$' | length) > 0)
    } | get 0?
}
let system_cert_dir = (get-system-cert-dir)
$env.SSL_CERT_DIR = if $system_cert_dir == null {
    $"($env.HOME)/.aspnet/dev-certs/trust"
} else {
    $"($env.HOME)/.aspnet/dev-certs/trust:($system_cert_dir)"
}

let dotnet_prefix = (brew-prefix-safe "dotnet")
if $dotnet_prefix != null {
    $env.DOTNET_ROOT = $"($dotnet_prefix)/libexec"
}

$env.PATH = ($env.PATH | prepend [
    #Dotnet tools on the PATH
    $"($env.HOME)/.dotnet/tools"
    #Expose cargo packages on PATH
    $"($env.HOME)/.cargo/bin"
])
let rustup_prefix = (brew-prefix-safe "rustup")
if $rustup_prefix != null {
    $env.PATH = ($env.PATH | prepend $"($rustup_prefix)/bin")
}


# ── Other environment variables ────────────────────────
$env.EDITOR = $"($brew_prefix)/bin/nvim"


# ── Shell integration bootstrap ───────────────────────────────────────────────
# Nu's `source` requires a static file path, so integrations that generate
# their init scripts dynamically must write to disk here in env.nu first.
# The resulting files are sourced in config.nu once the environment is ready.

#zoxide
#a "smarter cd" command. Makes it easier to jump to your favorite directories.
try-cmd-init "zoxide" { zoxide init nushell | save -f ~/.zoxide.nu }


#carapace completions - shell completions for all kinds of cool stuff
$env.CARAPACE_BRIDGES = 'cobra,argcomplete,clap'
mkdir $"($nu.cache-dir)"
try-cmd-init "carapace" { carapace _carapace nushell | save --force $"($nu.cache-dir)/carapace.nu" }
